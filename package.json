{
  "name": "proudly-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Proudly travel platform.",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @proudly/web dev",
    "dev:mobile": "pnpm --filter @proudly/mobile start",
    "build": "turbo build",
    "build:web": "pnpm --filter @proudly/web build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "2.5.4",
    "typescript": "5.8.3"
  }
}
